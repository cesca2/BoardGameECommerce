@page
@model BasketModel
@{double total = 0.0;}
<form method="post" id="autoForm">
    <input type="hidden" name="Basket" id="Basket" />
</form>


<script>

    window.addEventListener("load", function () {
        if (sessionStorage.getItem("submitted") == "true")
            return;
        // Read from localStorage
        const basket = JSON.parse(localStorage.getItem("basket"));

        console.log(basket);
        basket.forEach(entry => {
            console.log(entry.productId);
            console.log(entry.quantity);
        });
        document.getElementById("Basket").value = JSON.stringify(basket);
        document.getElementById("autoForm").submit();
        sessionStorage.setItem("submitted", "true");

        
    });
    window.addEventListener("beforeunload", function () {

    sessionStorage.removeItem("submitted");
});
</script>

<div class="d-flex justify-content-center mt-5">
<h1>Basket</h1>
</div>

@{if (Model.Products.Count > 0)
{
<div class="d-flex justify-content-center mt-5">
<table class="records" class="text-center">
    <thead>
        <tr>
            <th>Name</th>
            <th>Quantity</th>
            <th>Price</th>
            <th></th>

        </tr>
    </thead>

    <tbody>
    @foreach (var product in Model.Products)
    {
        <tr>
            <td>@product.Name</td>
            <td>@product.Quantity</td>
            <td>£@((product.Price * product.Quantity).ToString("0.00"))</td>
            <td><form method="get" asp-page="./Basket"><button onclick="removeFromBasket('@product.Id')">Remove from basket</button></form></td>

        </tr>
        total += product.Price * product.Quantity;
    }
    </tbody>
</table>
</div>

<div class="d-flex justify-content-center mt-5">
<h3>Total cost: £@total.ToString("0.00")</h3>
</div>

<div class="d-flex justify-content-center mt-5">
<form method="get" asp-page="./Checkout",>
<button style="font-size: 30px;"  type="submit", class="link_icon confirm", id="storefront"><i class="material-icons icon">shopping_cart_checkout</i> Checkout</button>
</form>
</div>
}
else{
    <div class="d-flex justify-content-center mt-5">
    <h3>Your basket is empty!</h3>
    </div>
}}