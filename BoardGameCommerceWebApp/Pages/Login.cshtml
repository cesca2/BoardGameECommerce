@page
@model LoginModel

<div class="d-flex justify-content-center mt-5">

<h1>Customer Login</h1>


</div>

<form method="post">
<div class="d-flex justify-content-center mt-5">
    <label>Email:</label>
    <input class="rounded-pill" type="text", asp-for="Email" />
</div>

@{ if (!@Model.ValidModelEntry) {
    <div class="d-flex justify-content-center mt-5">
        <p class="invalid_input">User not found with this email</p>
    </div class="d-flex justify-content-center mt-5">
    }
}

<div class="d-flex justify-content-center mt-5">
    <button type="submit" class="icon-btn send material-icons">send</button>
</div>
</form>
<div class="d-flex justify-content-center mt-5">

<a style="font-size: 20px;" asp-page="./CreateCustomer", type="submit", class="link_icon confirm", id="new_record"><i class="material-icons icon">person_add</i> New customer? Register here </a>
</div>